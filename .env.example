# =============================================================================
# xSuite Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# Frontend (Vite) — Required
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Supabase MCP Server (for Claude Code / AI coding tools)
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token

# -----------------------------------------------------------------------------
# Supabase Edge Functions — Set in Supabase Dashboard > Edge Functions > Secrets
# -----------------------------------------------------------------------------

# Supabase (auto-provided by Supabase runtime)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# CORS — restrict to your app domain
ALLOWED_ORIGIN=https://app.xsuite.io

# PayPal Integration
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox

# Email (Gmail SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# xSuite implements 3-layer rate limiting:
#
# Layer 1 — Database-backed (Edge Functions)
#   Automatic via check_rate_limit() RPC. No config needed.
#   | Endpoint                   | Limit   | Window | Key         |
#   |----------------------------|---------|--------|-------------|
#   | provision-tenant           | 1 req   | 60s    | IP + user   |
#   | send-document-email        | 5 req   | 60s    | user        |
#   | user-management            | 3 req   | 60s    | IP          |
#   | paypal-create-subscription | 3 req   | 60s    | user        |
#   | paypal-cancel-subscription | 2 req   | 60s    | user        |
#
# Layer 2 — Client-side (React app, defense-in-depth)
#   Automatic via rateLimiter.ts. No config needed.
#   Email sending, PDF generation, file upload, bulk import,
#   invoice conversion, case deletion, portal login.
#
# Layer 3 — Deployment layer (configure at reverse proxy / CDN)
#   RECOMMENDED additional protection:
#
#   Cloudflare WAF Rules:
#     - /functions/v1/provision-tenant: 3 req/hour per IP
#     - /functions/v1/send-document-email: 10 req/min per IP
#     - /functions/v1/user-management: 5 req/min per IP
#     - /functions/v1/paypal-*: 5 req/min per IP
#     - /auth/v1/token: 10 req/min per IP (Supabase Auth)
#     - General: 100 req/min per IP
#
#   Nginx example:
#     limit_req_zone $binary_remote_addr zone=auth:10m rate=10r/m;
#     limit_req_zone $binary_remote_addr zone=api:10m rate=100r/m;
#     location /functions/v1/ { limit_req zone=api burst=20 nodelay; }
#     location /auth/v1/token { limit_req zone=auth burst=5 nodelay; }
#
# Periodic cleanup — schedule via pg_cron or external cron:
#   SELECT cleanup_rate_limit_entries(); -- every 10 minutes

# -----------------------------------------------------------------------------
# Security Headers (configure at deployment layer for production)
# -----------------------------------------------------------------------------
# Dev/preview mode headers are set via vite.config.ts plugin.
# For production, configure these at your CDN/reverse proxy:
# - Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'
# - Strict-Transport-Security: max-age=31536000; includeSubDomains
# - X-Frame-Options: DENY
# - X-Content-Type-Options: nosniff
